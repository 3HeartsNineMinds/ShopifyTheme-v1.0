<section class="nm-landing" id="top">
  <div class="nm-grain" aria-hidden="true"></div>

  {% assign first_drop_product = all_products['hoodie'] %}

  <div class="nm-hero">
    <div class="nm-hero__copy">
      <div class="nm-eyebrow"><span class="nm-dot"></span>{{ section.settings.eyebrow }}</div>
      <h1>NINE<br><span>MINDS</span></h1>
      <p class="nm-lead">{{ section.settings.lead }}</p>

      {% form 'customer', class: 'nm-waitlist-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter, waitlist, nine-minds-first-drop">
        <div class="nm-waitlist-row">
          <input
            class="nm-waitlist-input"
            type="email"
            name="contact[email]"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            placeholder="Email address"
            required
          >
          <button class="nm-btn" type="submit">{{ section.settings.primary_label }}</button>
        </div>
        {% if form.posted_successfully? %}
          <p class="nm-form-message">You’re on the list. We’ll send updates before the first drop.</p>
        {% elsif form.errors %}
          <p class="nm-form-message nm-form-message--error">{{ form.errors | default_errors }}</p>
        {% endif %}
      {% endform %}

      <div class="nm-stats" aria-label="Brand launch stats">
        <div><strong>{{ section.settings.stat_one_value }}</strong><span>{{ section.settings.stat_one_label }}</span></div>
        <div><strong>{{ section.settings.stat_two_value }}</strong><span>{{ section.settings.stat_two_label }}</span></div>
        <div><strong>{{ section.settings.stat_three_value }}</strong><span>{{ section.settings.stat_three_label }}</span></div>
      </div>
    </div>

    <div class="nm-visual" aria-label="Nine Minds first drop product">
      <div class="nm-logo-mark" aria-hidden="true">
        <svg viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M250 70c-48 0-83 36-83 86 0 26 8 45 24 60-23 8-49 20-78 42-32 24-55 52-69 83 38-18 70-27 96-27 17 0 31 4 42 11-36 29-58 65-69 109 35-21 66-29 93-24 15 3 27 9 37 18-1-45 8-82 28-111 20 29 29 66 28 111 10-9 22-15 37-18 27-5 58 3 93 24-11-44-33-80-69-109 11-7 25-11 42-11 26 0 58 9 96 27-14-31-37-59-69-83-29-22-55-34-78-42 16-15 24-34 24-60 0-50-35-86-83-86Z" fill="currentColor"/>
          <path d="M162 180c-58 9-95 39-111 89 40-23 75-28 105-14 15 7 27 18 36 32M338 180c58 9 95 39 111 89-40-23-75-28-105-14-15 7-27 18-36 32M205 269c-59 42-79 92-60 150 25-36 54-54 87-54M295 269c59 42 79 92 60 150-25-36-54-54-87-54" stroke="currentColor" stroke-width="28" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <a class="nm-drop-card" href="/products/hoodie" aria-label="View the Nine Minds hoodie product">
        <div class="nm-drop-card__image">
          {% if first_drop_product.featured_image %}
            {{ first_drop_product.featured_image | image_url: width: 760 | image_tag: loading: 'eager', alt: first_drop_product.title }}
          {% else %}
            <div class="nm-product-placeholder">
              <span>NINE MINDS</span>
            </div>
          {% endif %}
        </div>
        <div class="nm-drop-card__content">
          <span>First drop</span>
          <strong>{% if first_drop_product != blank %}{{ first_drop_product.title }}{% else %}NINE MINDS HOODIE{% endif %}</strong>
          <small>{% if first_drop_product != blank %}{{ first_drop_product.price | money }}{% else %}Premium streetwear concept{% endif %}</small>
        </div>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nine Minds landing",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Coming soon / first drop" },
    { "type": "textarea", "id": "lead", "label": "Lead text", "default": "A monochrome clothing brand for the ones who live between moods. Clean silhouettes, dark visuals, octopus energy and a premium streetwear feel." },
    { "type": "text", "id": "primary_label", "label": "Waitlist button label", "default": "Join the waitlist" },
    { "type": "text", "id": "stat_one_value", "label": "Stat one value", "default": "3.5K" },
    { "type": "text", "id": "stat_one_label", "label": "Stat one label", "default": "30 day views" },
    { "type": "text", "id": "stat_two_value", "label": "Stat two value", "default": "9" },
    { "type": "text", "id": "stat_two_label", "label": "Stat two label", "default": "Launch posts" },
    { "type": "text", "id": "stat_three_value", "label": "Stat three value", "default": "01" },
    { "type": "text", "id": "stat_three_label", "label": "Stat three label", "default": "Signature hoodie" }
  ],
  "presets": [{ "name": "Nine Minds landing" }]
}
{% endschema %}
