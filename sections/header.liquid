<header class="site-header">
  <div class="page-width site-header__inner">
    <a class="site-brand" href="{{ routes.root_url }}">NINE<span>MINDS</span></a>

    {% if section.settings.menu != blank %}
      <nav class="site-nav" aria-label="Primary navigation">
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </nav>
    {% endif %}

    <div class="site-nav">
      {% if settings.instagram_handle != blank %}
        <a class="social-link" href="{{ settings.instagram_url | default: 'https://www.instagram.com/_nineminds_/' }}" target="_blank" rel="noopener">{{ settings.instagram_handle }}</a>
      {% endif %}
      <a class="cart-link" href="{{ routes.cart_url }}">Cart / {{ cart.item_count }}</a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Menu" }
  ]
}
{% endschema %}
