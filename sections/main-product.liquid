<section class="section product-section" data-product-section>
  <div class="page-width product-layout">
    <div class="product-media-panel">
      <div class="product-media-gallery" aria-label="Product photos">
        {% assign image_count = product.images.size %}

        {% if image_count > 0 %}
          {% for image in product.images %}
            <input
              class="product-media-toggle"
              type="radio"
              name="product-media-{{ section.id }}"
              id="product-media-{{ section.id }}-{{ forloop.index }}"
              {% if forloop.first %}checked{% endif %}
            >
          {% endfor %}

          <div class="product-media-slides">
            {% for image in product.images %}
              {% if forloop.last %}
                {% assign next_index = 1 %}
              {% else %}
                {% assign next_index = forloop.index | plus: 1 %}
              {% endif %}

              <div class="product-media-slide product-media-slide--{{ forloop.index }}">
                {{ image | image_url: width: 1400 | image_tag: class: 'media product-media', loading: 'eager', alt: product.title }}

                {% if image_count > 1 %}
                  <label class="product-media-next" for="product-media-{{ section.id }}-{{ next_index }}" aria-label="Show next product photo">
                    Next photo
                    <span aria-hidden="true">→</span>
                  </label>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% elsif product.featured_image %}
          <div class="product-media-slides">
            <div class="product-media-slide product-media-slide--1 is-visible">
              {{ product.featured_image | image_url: width: 1400 | image_tag: class: 'media product-media', loading: 'eager', alt: product.title }}
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="product-info-panel">
      <p class="section-kicker">Nine Minds piece</p>
      <h1 class="section-title product-title">{{ product.title }}</h1>

      <p class="price product-price" data-product-price>{{ product.selected_or_first_available_variant.price | money }}</p>

      {% if product.description != blank %}
        <div class="rte product-description">{{ product.description }}</div>
      {% endif %}

      {% form 'product', product, data-cart-add: true, class: 'product-form' %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-id>

        {% unless product.has_only_default_variant %}
          <fieldset class="variant-picker" data-variant-picker>
            <legend>Choose size</legend>
            <div class="variant-options">
              {% for variant in product.variants %}
                <label class="variant-option {% unless variant.available %}variant-option--sold-out{% endunless %}">
                  <input
                    type="radio"
                    name="variant_choice"
                    value="{{ variant.id }}"
                    data-variant-input
                    data-price="{{ variant.price | money }}"
                    data-available="{{ variant.available }}"
                    {% if variant.id == product.selected_or_first_available_variant.id %}checked{% endif %}
                    {% unless variant.available %}disabled{% endunless %}
                  >
                  <span class="variant-option__content">
                    <span class="variant-option__title">{{ variant.title }}</span>
                    <span class="variant-option__price">{{ variant.price | money }}</span>
                  </span>
                </label>
              {% endfor %}
            </div>
          </fieldset>
        {% endunless %}

        <div class="product-actions">
          <button class="button product-submit" type="submit" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %} data-add-to-cart>
            {% if product.selected_or_first_available_variant.available %}Add to cart{% else %}Sold out{% endif %}
          </button>
          <a class="button button--secondary" href="{{ routes.cart_url }}">View cart</a>
        </div>
      {% endform %}
    </div>
  </div>
</section>

<style>
  [data-product-section] .variant-option--sold-out .variant-option__title,
  [data-product-section] .variant-option--sold-out .variant-option__price {
    text-decoration: none !important;
    color: #ffffff !important;
    -webkit-text-fill-color: #ffffff !important;
    position: relative !important;
    z-index: 4 !important;
    text-shadow: 0 1px 10px rgba(0,0,0,.45) !important;
  }

  [data-product-section] .variant-option--sold-out .variant-option__content {
    position: relative !important;
    isolation: isolate !important;
    overflow: hidden !important;
    opacity: .92 !important;
    cursor: not-allowed !important;
    border-color: rgba(255,255,255,.28) !important;
    background:
      radial-gradient(circle at 18% 72%, rgba(0,0,0,.98) 0 9px, transparent 10px),
      radial-gradient(circle at 23% 63%, rgba(0,0,0,.82) 0 5px, transparent 6px),
      radial-gradient(circle at 75% 29%, rgba(0,0,0,.95) 0 13px, transparent 14px),
      radial-gradient(circle at 84% 41%, rgba(0,0,0,.72) 0 5px, transparent 6px),
      radial-gradient(circle at 61% 77%, rgba(0,0,0,.58) 0 4px, transparent 5px),
      linear-gradient(135deg, #34322f 0%, #151515 100%) !important;
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,.12),
      0 16px 44px rgba(0,0,0,.34) !important;
  }

  [data-product-section] .variant-option--sold-out .variant-option__content::before,
  [data-product-section] .variant-option--sold-out .variant-option__content::after {
    content: "" !important;
    position: absolute !important;
    z-index: 2 !important;
    pointer-events: none !important;
    background: #020202 !important;
    filter: blur(.2px) !important;
  }

  [data-product-section] .variant-option--sold-out .variant-option__content::before {
    width: 96px !important;
    height: 58px !important;
    right: -15px !important;
    top: -7px !important;
    border-radius: 55% 45% 62% 38% / 45% 60% 40% 55% !important;
    transform: rotate(-19deg) !important;
    box-shadow:
      -18px 22px 0 -27px #020202,
      -34px 17px 0 -31px #020202,
      -43px 42px 0 -34px #020202,
      -5px 71px 0 -36px #020202,
      -66px 61px 0 -39px #020202,
      -77px 4px 0 -41px #020202,
      19px 50px 0 -36px #020202 !important;
  }

  [data-product-section] .variant-option--sold-out .variant-option__content::after {
    width: 118px !important;
    height: 74px !important;
    left: -28px !important;
    bottom: -18px !important;
    border-radius: 50% 58% 44% 62% / 58% 43% 62% 47% !important;
    transform: rotate(24deg) !important;
    background: rgba(0,0,0,.92) !important;
    box-shadow:
      34px -38px 0 -31px #020202,
      62px -21px 0 -37px #020202,
      82px -53px 0 -41px #020202,
      113px -14px 0 -45px #020202,
      96px 23px 0 -39px #020202,
      28px 62px 0 -43px #020202 !important;
  }

  [data-product-section] .variant-option--sold-out .variant-option__content .variant-option__title::after {
    content: "SOLD OUT" !important;
    display: inline-block !important;
    margin-left: .65rem !important;
    padding: .18rem .38rem !important;
    border: 1px solid rgba(255,255,255,.58) !important;
    border-radius: 999px !important;
    color: #ffffff !important;
    font-size: .52rem !important;
    letter-spacing: .12em !important;
    vertical-align: middle !important;
  }

  @media (min-width: 881px) {
    html,
    body {
      overflow: hidden !important;
    }

    .main-content:has([data-product-section]) {
      height: 100vh !important;
      overflow: hidden !important;
    }

    [data-product-section].product-section {
      height: 100vh !important;
      max-height: 100vh !important;
      overflow: hidden !important;
      padding-top: 96px !important;
      padding-bottom: 24px !important;
    }

    [data-product-section] .product-layout {
      height: calc(100vh - 120px) !important;
      align-items: stretch !important;
    }

    [data-product-section] .product-media-panel,
    [data-product-section] .product-info-panel {
      height: 100% !important;
      overflow: hidden !important;
    }

    [data-product-section] .product-media-gallery,
    [data-product-section] .product-media-slides {
      position: relative !important;
      height: 100% !important;
      overflow: hidden !important;
    }

    [data-product-section] .product-media-toggle {
      position: absolute !important;
      opacity: 0 !important;
      pointer-events: none !important;
    }

    [data-product-section] .product-media-slide {
      position: absolute !important;
      inset: 0 !important;
      display: grid !important;
      place-items: center !important;
      opacity: 0 !important;
      visibility: hidden !important;
      transition: opacity .3s ease, visibility .3s ease !important;
    }

    [data-product-section] .product-media-toggle:nth-of-type(1):checked ~ .product-media-slides .product-media-slide--1,
    [data-product-section] .product-media-toggle:nth-of-type(2):checked ~ .product-media-slides .product-media-slide--2,
    [data-product-section] .product-media-toggle:nth-of-type(3):checked ~ .product-media-slides .product-media-slide--3,
    [data-product-section] .product-media-toggle:nth-of-type(4):checked ~ .product-media-slides .product-media-slide--4,
    [data-product-section] .product-media-toggle:nth-of-type(5):checked ~ .product-media-slides .product-media-slide--5,
    [data-product-section] .product-media-toggle:nth-of-type(6):checked ~ .product-media-slides .product-media-slide--6,
    [data-product-section] .product-media-toggle:nth-of-type(7):checked ~ .product-media-slides .product-media-slide--7,
    [data-product-section] .product-media-toggle:nth-of-type(8):checked ~ .product-media-slides .product-media-slide--8,
    [data-product-section] .product-media-slide.is-visible {
      opacity: 1 !important;
      visibility: visible !important;
    }

    [data-product-section] .product-media {
      width: 100% !important;
      height: 100% !important;
      max-height: 100% !important;
      object-fit: contain !important;
      aspect-ratio: auto !important;
      background: #080808 !important;
    }

    [data-product-section] .product-media-next {
      position: absolute !important;
      right: 18px !important;
      bottom: 18px !important;
      display: inline-flex !important;
      align-items: center !important;
      gap: .5rem !important;
      padding: .65rem .85rem !important;
      border: 1px solid rgba(5,5,5,.18) !important;
      border-radius: 999px !important;
      background: rgba(246,246,243,.82) !important;
      color: #050505 !important;
      text-transform: uppercase !important;
      letter-spacing: .12em !important;
      font-size: .68rem !important;
      font-weight: 900 !important;
      cursor: pointer !important;
      backdrop-filter: blur(10px) !important;
      box-shadow: 0 14px 44px rgba(0,0,0,.18) !important;
      transition: transform .2s ease, background .2s ease !important;
      z-index: 5 !important;
    }

    [data-product-section] .product-media-next:hover {
      transform: translateY(-2px) !important;
      background: #fff !important;
    }

    [data-product-section] .product-info-panel {
      display: flex !important;
      flex-direction: column !important;
      justify-content: center !important;
    }

    [data-product-section] .product-title {
      color: #f6f6f3 !important;
      -webkit-text-fill-color: #f6f6f3 !important;
      text-shadow: 0 0 34px rgba(236,231,220,.24) !important;
      opacity: 1 !important;
      filter: none !important;
      font-size: clamp(3rem, 5.5vw, 5.8rem) !important;
      margin-bottom: 1rem !important;
    }

    [data-product-section] .product-description {
      max-height: 22vh !important;
      overflow: hidden !important;
    }
  }
</style>

{% schema %}
{ "name": "Main product", "settings": [] }
{% endschema %}
