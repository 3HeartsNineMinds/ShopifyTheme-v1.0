<section class="hero">
  <div class="page-width">
    <p>{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.text }}</p>
    {% if section.settings.button_label != blank %}
      <a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Nine Minds" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built for the ones who move different" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "A clean Shopify theme foundation for premium streetwear drops, product storytelling, and conversion-focused shopping." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
