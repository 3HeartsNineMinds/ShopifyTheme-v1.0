<article class="card product-card">
  <a href="{{ product.url }}">
    {% if product.featured_image %}
      {{ product.featured_image | image_url: width: 700 | image_tag: class: 'media', loading: 'lazy' }}
    {% endif %}
    <div class="card__content">
      <h3>{{ product.title }}</h3>
      <p class="price">{{ product.price | money }}</p>
    </div>
  </a>
</article>
